{
    "name": "maarheeze/uuid-symfony",
    "description": "symfony integration for a simple uuid value object",
    "type": "library",
    "license": "MIT",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Maarheeze\\Uuid\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "maarheeze/uuid": "^1.0",
        "symfony/serializer": "^8.0"
    },
    "require-dev": {
        "maarheeze/phpcs": "^1.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12"
    }
}
